import express from "express";
import fs from "fs";
import path from "path";
import { composeBrainPrompt } from "../brain/composeBrainPrompt";

export const hqRouter = express.Router();

function loadInstalledMeganHQPrompt(): string {
  const promptPath = path.resolve(process.cwd(), "../../brain/megan_hq_system_prompt.txt");

  try {
    return fs.readFileSync(promptPath, "utf8").trim();
  } catch {
    return "";
  }
}

hqRouter.post("/chat", async (req, res) => {
  try {
    const message = String(req.body?.message || "").trim();

    if (!message) {
      return res.status(400).json({ error: "message required" });
    }

    let dashboardState: any = {};
    try {
      const dashboardRes = await fetch("http://127.0.0.1:4000/dashboard/state");
      dashboardState = await dashboardRes.json();
    } catch {
      dashboardState = {};
    }

    const installedSystemPrompt = loadInstalledMeganHQPrompt();
    const runtimePrompt = composeBrainPrompt(dashboardState);

    const systemPrompt = [
      installedSystemPrompt,
      "",
      "RUNTIME CONTEXT",
      runtimePrompt
    ]
      .filter(Boolean)
      .join("\n\n");

    const openaiRes = await fetch("https://api.openai.com/v1/responses", {
      method: "POST",
      headers: {
        Authorization: `Bearer ${process.env.OPENAI_API_KEY}`,
        "Content-Type": "application/json"
      },
      body: JSON.stringify({
        model: process.env.OPENAI_MODEL || "gpt-4.1-mini",
        input: [
          {
            role: "system",
            content: [{ type: "input_text", text: systemPrompt }]
          },
          {
            role: "user",
            content: [{ type: "input_text", text: message }]
          }
        ]
      })
    });

    if (!openaiRes.ok) {
      const errorText = await openaiRes.text();
      return res.status(500).json({
        error: "OpenAI request failed",
        details: errorText
      });
    }

    const data = await openaiRes.json();

    const text =
      data.output_text ||
      data.output
        ?.flatMap((item: any) => item.content || [])
        ?.filter((content: any) => content.type === "output_text")
        ?.map((content: any) => content.text)
        ?.join("\n") ||
      "No response";

    res.json({
      reply: text,
      meta: {
        brain_prompt_loaded: Boolean(installedSystemPrompt),
        dashboard_context_loaded: Boolean(dashboardState)
      }
    });
  } catch (err: any) {
    res.status(500).json({ error: err.message });
  }
});
