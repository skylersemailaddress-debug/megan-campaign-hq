import "dotenv/config";
import express from "express";
import cors from "cors";

import { intakeRouter } from "./routes/intake";
import { dashboardRouter } from "./routes/dashboard";
import { approvalsRouter } from "./routes/approvals";
import { reportsRouter } from "./routes/reports";
import { analyticsRouter } from "./routes/analytics";
import { hqRouter } from "./routes/hq";

const app = express();
const port = Number(process.env.PORT || 4000);

app.use(cors({ origin: true, credentials: true }));
app.use(express.json());

app.get("/", (_req, res) => {
  res.json({
    ok: true,
    service: "Megan Campaign HQ API",
  });
});

app.get("/health", (_req, res) => {
  res.json({ ok: true });
});

app.use("/intake", intakeRouter);
app.use("/dashboard", dashboardRouter);
app.use("/approvals", approvalsRouter);
app.use("/reports", reportsRouter);
app.use("/analytics", analyticsRouter);
app.use("/hq", hqRouter);

// Megan HQ Health Patch
app.get("/dashboard/state", async (_req, res) => {
  res.json({
    ok: true,
    api: "live",
    source: "local",
    timestamp: new Date().toISOString(),
    today: {
      priorityCount: 0,
      items: [],
      label: "API live",
      status: "ok",
    },
    signals: {
      openCount: 0,
      monitoredCount: 0,
      byCategory: [],
      items: [],
    },
    approvals: {
      pendingCount: 0,
      recentCount: 0,
      byType: [],
      items: [],
    },
    events: {
      count: 0,
      items: [],
    },
    websiteQueue: {
      count: 0,
      items: [],
    },
  });
});

app.get("/health", (_req, res) => {
  res.json({
    ok: true,
    api: "live",
    timestamp: new Date().toISOString(),
  });
});

app.get("/hq/chat", (_req, res) => {
  res.status(405).json({
    ok: false,
    error: "Method Not Allowed",
    message: "Use POST /hq/chat",
  });
});
// End Megan HQ Health Patch
app.listen(port, () => {
  console.log(`Megan Campaign HQ API listening on http://localhost:${port}`);
});


